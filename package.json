{
  "name": "tenderguard",
  "version": "1.0.0",
  "description": "TenderGuard supplier document review and metadata editor",
  "author": "TenderGuard",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "test:ui": "node scripts/ui-smoke.js",
    "analyze": "node src/cli.js",
    "dist:win": "electron-builder --win zip --x64",
    "dist:mac": "electron-builder --mac zip --universal"
  },
  "dependencies": {
    "exceljs": "4.4.0",
    "fast-xml-parser": "5.2.5",
    "pdf-lib": "1.17.1",
    "yazl": "3.3.1",
    "yauzl": "3.2.0"
  },
  "devDependencies": {
    "electron": "37.2.3",
    "electron-builder": "26.0.12"
  },
  "build": {
    "appId": "com.tenderguard.desktop",
    "productName": "TenderGuard",
    "asar": true,
    "icon": "src/ui/assets/tenderguard-logo.png",
    "afterPack": "scripts/after-pack.js",
    "files": [
      "src/**/*",
      "package.json",
      "README.md",
      "LICENSES.md"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "zip",
      "icon": "src/ui/assets/tenderguard-logo.ico",
      "executableName": "TenderGuard",
      "artifactName": "TenderGuard-${version}-Windows-${arch}.${ext}",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "zip",
      "category": "public.app-category.business",
      "artifactName": "TenderGuard-${version}-macOS-${arch}.${ext}"
    }
  }
}
